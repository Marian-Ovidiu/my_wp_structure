# ❌ Config locali e file sensibili
!wp-config.php

# ❌ Ignora tutta la wp-content (ma solo se non serve)
# wp-content/* ← LO RIMUOVIAMO perché vogliamo plugin e tema custom

# ✅ Mantieni TUTTI i plugin installati (anche WP Mail SMTP ecc.)
!wp-content/plugins/
wp-content/plugins/*/node_modules/
wp-content/plugins/*/vendor/ # se non vuoi vendor nei plugin

# ✅ Mantieni SOLO il tuo tema custom
!wp-content/themes/
!wp-content/themes/my_structure/**
wp-content/themes/*/node_modules/
wp-content/themes/*/vendor/

# ❌ Ignora le robe runtime
wp-content/cache/
wp-content/uploads/
wp-content/debug.log
wp-content/upgrade/
wp-content/upgrade-temp-backup/
wp-content/wc-logs/
*.log

# ❌ File di sistema e dipendenze
.DS_Store
Thumbs.db
node_modules/
vendor/

# ❌ Backup o export
*.sql
*.zip
*.tar.gz
*.bak
*.bk
